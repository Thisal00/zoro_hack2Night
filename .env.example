POSTGRES_USER=postgresql
POSTGRES_PASSWORD=supersecurepassword
POSTGRES_DB=htn26db
DATABASE_URL=postgresql://postgres:supersecurepassword@db:5432/htn26db

# Secret used to sign session tokens (required). Use a long random value,
# e.g. `openssl rand -hex 32`. The app will not start a valid session without it.
SESSION_SECRET=replace-with-a-long-random-secret

